# =============================================
# PH POLL — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git!
# =============================================

# Supabase (get from supabase.com → project → settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (get from upstash.com → create database → REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret for hashing IPs (generate with: openssl rand -hex 32)
IP_HASH_SECRET=

# Cloudinary (get from cloudinary.com → dashboard)
# Only needed if you want photo uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
